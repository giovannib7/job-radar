<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.giovanni.jobradar</string>

  <!-- What to run -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/giovanniborraccia/Desktop/PhD research/job_radar/run.sh</string>
  </array>

  <!-- When: every day at 08:00. If the Mac is asleep, it runs at next wake. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/giovanniborraccia/Desktop/PhD research/job_radar/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/giovanniborraccia/Desktop/PhD research/job_radar/launchd.err.log</string>
</dict>
</plist>
